{
  "name": "rocketclaw2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Node.js and TypeScript reimplementation of RocketClaw",
  "files": [
    "dist/src/**",
    "README.md",
    "docs/**",
    "LICENSE*"
  ],
  "bin": {
    "rocketclaw2": "dist/src/cli.js"
  },
  "scripts": {
    "clean": "node -e \"import('node:fs').then(fs => fs.rmSync('dist', { recursive: true, force: true }))\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "verify:build": "node scripts/verify-build.mjs",
    "verify:pack": "node scripts/verify-pack.mjs",
    "prepack": "npm run build && npm run verify:build",
    "prepublishOnly": "npm run verify:build && npm run verify:pack",
    "dev": "tsx src/cli.ts",
    "start": "node dist/src/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "pino": "^9.7.0",
    "undici": "^6.21.2",
    "yaml": "^2.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^2.1.9"
  }
}
